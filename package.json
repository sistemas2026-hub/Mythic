{
  "name": "mythic-app",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema de gestión para tienda de perfumería (móvil nativo + web)",
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:types": "supabase gen types typescript --local --schema public > packages/core/src/database.generated.ts"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "supabase": "^2.2.1",
    "turbo": "^2.3.4",
    "typescript": "^5.7.3"
  }
}
